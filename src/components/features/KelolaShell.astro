---
import Layout from "../../layouts/Layout.astro";

interface Props {
  storeId: string;
  storeName: string;
  storeLogo?: string;
  active: "dashboard" | "anggota" | "produk" | "droppoint";
  title: string;
}

const { storeId, storeName, storeLogo, active, title } = Astro.props;
const base = `/toko/${storeId}/kelola`;
const logo = storeLogo ?? "https://placehold.co/128x128/269dd8/ffffff?text=K";

const tabs = [
  { id: "dashboard", label: "Dashboard", href: base, icon: "dashboard" },
  { id: "anggota", label: "Anggota", href: `${base}/anggota`, icon: "users" },
  { id: "produk", label: "Produk", href: `${base}/produk`, icon: "box" },
  { id: "droppoint", label: "Drop Point", href: `${base}/droppoint`, icon: "pin" },
] as const;

const icons: Record<string, string> = {
  dashboard: "M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z",
  users: "M9 8a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7zM2.5 20c.8-3 3.4-5 6.5-5s5.7 2 6.5 5M17.5 9a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5zM16 15c2.5 0 4.7 1.8 5.5 4",
  box: "M21 8 12 3 3 8v8l9 5 9-5V8zM3 8l9 5 9-5M12 13v8",
  pin: "M12 21s-7-6.5-7-12a7 7 0 1 1 14 0c0 5.5-7 12-7 12zM12 12a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z",
  back: "m14 6-6 6 6 6",
  cart: "M2 3h2.5l2.6 12.4a1.5 1.5 0 0 0 1.5 1.1h8.9a1.5 1.5 0 0 0 1.4-1.1L21 8H6",
};
---

<Layout title={`${title} — Pasar Koperasi`}>
  <div class="flex min-h-screen flex-col bg-cream lg:flex-row">
    <!-- Sidebar desktop -->
    <aside class="hidden w-64 shrink-0 flex-col bg-brand-deep px-4 py-6 text-white lg:flex">
      <a href="/" class="flex items-center gap-2.5 px-2">
        <img src={logo} alt={`Logo ${storeName}`} class="h-10 w-10 rounded-lg" />
        <span>
          <span class="block font-display text-base font-bold leading-tight">{storeName}</span>
          <span class="block text-[10px] font-semibold uppercase tracking-[0.18em] text-amber">Pasar Koperasi</span>
        </span>
      </a>

      <nav class="mt-8 space-y-1" aria-label="Menu kelola toko">
        {
          tabs.map((tab) => (
            <a
              href={tab.href}
              aria-current={active === tab.id ? "page" : undefined}
              class:list={[
                "flex items-center gap-3 rounded-lg px-3.5 py-2.5 text-sm font-semibold transition-colors",
                active === tab.id
                  ? "bg-white/15 text-white"
                  : "text-white/65 hover:bg-white/10 hover:text-white",
              ]}
            >
              <svg class="h-4.5 w-4.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={icons[tab.icon]} />
              </svg>
              {tab.label}
            </a>
          ))
        }
        <p class="px-3.5 pb-1 pt-5 text-[10px] font-bold uppercase tracking-[0.18em] text-white/35">Lainnya</p>
        <a href="/toko" class="flex items-center gap-3 rounded-lg px-3.5 py-2.5 text-sm font-semibold text-white/65 transition-colors hover:bg-white/10 hover:text-white">
          <svg class="h-4.5 w-4.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d={icons.back} />
          </svg>
          Toko Saya
        </a>
        <a href="/" class="flex items-center gap-3 rounded-lg px-3.5 py-2.5 text-sm font-semibold text-white/65 transition-colors hover:bg-white/10 hover:text-white">
          <svg class="h-4.5 w-4.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d={icons.cart} />
          </svg>
          Kembali Belanja
        </a>
      </nav>
    </aside>

    <!-- Bar atas mobile -->
    <div class="bg-brand-deep px-4 py-3 text-white lg:hidden">
      <div class="flex items-center gap-2.5">
        <img src={logo} alt={`Logo ${storeName}`} class="h-9 w-9 rounded-lg" />
        <span class="min-w-0">
          <span class="block truncate font-display text-base font-bold leading-tight">{storeName}</span>
          <span class="block text-[10px] font-semibold uppercase tracking-[0.18em] text-amber">Pasar Koperasi</span>
        </span>
        <a href="/toko" class="ml-auto text-xs font-semibold text-white/70 hover:text-white">← Toko Saya</a>
      </div>
      <nav class="mt-3 flex gap-1.5 overflow-x-auto pb-1" aria-label="Menu kelola toko">
        {
          tabs.map((tab) => (
            <a
              href={tab.href}
              aria-current={active === tab.id ? "page" : undefined}
              class:list={[
                "shrink-0 rounded-full px-3 py-2 text-xs font-semibold transition-colors",
                active === tab.id ? "bg-white/15 text-white" : "text-white/65 hover:bg-white/10 hover:text-white",
              ]}
            >
              {tab.label}
            </a>
          ))
        }
      </nav>
    </div>

    <!-- Konten utama -->
    <main class="min-w-0 flex-1 px-4 py-6 sm:px-8 sm:py-8">
      <slot />
    </main>
  </div>
</Layout>