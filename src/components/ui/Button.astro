---
import { cn } from "../../lib/utils";

interface Props {
  variant?: "primary" | "secondary";
  class?: string;
}

const { variant = "primary", class: className } = Astro.props;
---

<button
  class={cn(
    "rounded-full px-4 py-2 text-sm font-semibold transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand",
    variant === "primary"
      ? "bg-brand text-white hover:bg-brand-dark"
      : "border border-ink/10 bg-white text-ink hover:border-brand hover:text-brand",
    className,
  )}
>
  <slot />
</button>
