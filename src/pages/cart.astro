---
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/features/SiteHeader.astro";
import SiteFooter from "../components/features/SiteFooter.astro";
import CartView from "../components/react/CartView";
---

<Layout title="Keranjang — Pasar Koperasi">
  <SiteHeader showSearch={false} showCategories={false} />
  <main class="mx-auto max-w-4xl px-4 py-12">
    <header class="mb-7">
      <p class="text-xs font-bold uppercase tracking-[0.18em] text-amber-deep">Belanja</p>
      <h1 class="mt-1 font-display text-3xl font-bold">Keranjang</h1>
    </header>
    <CartView client:load />
  </main>
  <SiteFooter />
</Layout>
