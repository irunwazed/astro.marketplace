---
import KelolaShell from "../../../../components/features/KelolaShell.astro";
import StoreDropPointsManager from "../../../../components/react/StoreDropPointsManager";
import { myStore } from "../../../../data/my-store";
import { dropPoints } from "../../../../data/drop-points";

export function getStaticPaths() {
  return [{ params: { idtoko: "ST-1" } }, { params: { idtoko: "ST-2" } }];
}

const { idtoko } = Astro.params;
const store = idtoko === "ST-1" ? myStore : { name: "Kopi Tani Makmur", logo: "https://placehold.co/128x128/df2463/ffffff?text=KT", dropPointIds: ["DP-1", "DP-3"] };
const storeDropPointIds = idtoko === "ST-1" ? myStore.dropPointIds : ["DP-1", "DP-3"];
---

<KelolaShell storeId={idtoko} storeName={store.name} storeLogo={store.logo} active="droppoint" title="Kelola Drop Point">
  <header class="mb-6">
    <p class="text-xs font-bold uppercase tracking-[0.18em] text-amber-deep">Penjual</p>
    <h1 class="mt-1 font-display text-3xl font-bold">Kelola Drop Point</h1>
  </header>
  <StoreDropPointsManager
    storeId={idtoko}
    masterDropPoints={dropPoints}
    initialDropPointIds={storeDropPointIds}
    client:load
  />
</KelolaShell>