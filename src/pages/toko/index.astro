---
import Layout from "../../layouts/Layout.astro";
import SiteHeader from "../../components/features/SiteHeader.astro";
import SiteFooter from "../../components/features/SiteFooter.astro";
import { myMemberships } from "../../data/my-store";
---

<Layout title="Toko Saya — Pasar Koperasi">
  <SiteHeader showSearch={false} showCategories={false} />
  <main class="mx-auto max-w-3xl px-4 py-12">
    <header class="mb-7 flex flex-wrap items-end justify-between gap-3">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.18em] text-amber-deep">Penjual</p>
        <h1 class="mt-1 font-display text-3xl font-bold">Toko Saya</h1>
        <p class="mt-2 text-sm text-moss">
          Satu akun bisa mendirikan beberapa toko atau bergabung sebagai staff.
        </p>
      </div>
      <a
        href="/toko/buat"
        class="rounded-full bg-forest px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-forest-dark"
      >
        + Buat Toko
      </a>
    </header>

    <ul class="space-y-3">
      {
        myMemberships.map((m) => (
          <li>
            <a
              href="/toko/kelola"
              class="flex items-center gap-4 rounded-xl border border-ink/10 bg-white p-4 transition-colors hover:border-forest"
            >
              <img src={m.logo} alt={`Logo ${m.storeName}`} class="h-12 w-12 rounded-xl" />
              <span class="min-w-0 flex-1">
                <span class="block truncate font-display text-lg font-bold">{m.storeName}</span>
                <span class="block text-xs text-moss">{m.productCount} produk</span>
              </span>
              <span
                class:list={[
                  "rounded-full px-3 py-1 text-[11px] font-bold uppercase",
                  m.role === "owner" ? "bg-forest text-white" : "bg-forest/10 text-forest",
                ]}
              >
                {m.role}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </main>
  <SiteFooter />
</Layout>
