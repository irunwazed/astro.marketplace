---
import Layout from "../../layouts/Layout.astro";
import SiteHeader from "../../components/features/SiteHeader.astro";
import SiteFooter from "../../components/features/SiteFooter.astro";
import OrdersList from "../../components/react/OrdersList";
import { orders } from "../../data/orders";
---

<Layout title="Pesanan Saya — Pasar Koperasi">
  <SiteHeader showSearch={false} showCategories={false} />
  <main class="mx-auto max-w-3xl px-4 py-12">
    <header class="mb-7">
      <p class="text-xs font-bold uppercase tracking-[0.18em] text-amber-deep">Belanja</p>
      <h1 class="mt-1 font-display text-3xl font-bold">Pesanan Saya</h1>
      <p class="mt-2 text-sm text-moss">
        Pantau status pesanan sampai barang diterima — pesanan hasil checkout Anda muncul paling
        atas.
      </p>
    </header>
    <OrdersList demoOrders={orders} client:load />
  </main>
  <SiteFooter />
</Layout>
