---
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/features/SiteHeader.astro";
import SiteFooter from "../components/features/SiteFooter.astro";
import ProductCard, { formatIDR } from "../components/react/ProductCard";
import { products } from "../data/products";
import { stores } from "../data/stores";

const heroHighlights = products.slice(0, 3);
const featured = products.slice(0, 8);

const stats = [
  { value: "24", label: "Mitra UMKM" },
  { value: "340+", label: "Produk tersedia" },
  { value: "4.8★", label: "Rating rata-rata" },
];

const banners = [
  {
    title: "Poin Simpanan Otomatis",
    body: "Setiap belanja menambah saldo simpanan sukarela Anda.",
    class: "bg-brand",
  },
  {
    title: "Isi Pulsa & Bayar Tagihan",
    body: "PPOB terintegrasi langsung dari akun koperasi Anda.",
    class: "bg-amber",
  },
  {
    title: "Jadi Mitra UMKM",
    body: "Titip produk Anda dan jangkau seluruh anggota koperasi.",
    class: "bg-rose",
  },
];
---

<Layout title="Pasar Koperasi — Belanja Produk Anggota & UMKM">
  <SiteHeader />
  <main class="mx-auto max-w-6xl px-4">
    <section
      class="mt-6 rounded-3xl bg-gradient-to-br from-brand to-brand-deep px-6 py-10 text-white sm:px-10 sm:py-12"
    >
      <div class="flex flex-col items-start gap-10 lg:flex-row lg:items-center">
        <div class="flex-1">
          <p
            class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.15em]"
          >
            <span class="h-1.5 w-1.5 rounded-full bg-amber" aria-hidden="true"></span>
            Konsinyasi UMKM Anggota
          </p>
          <h1 class="mt-5 font-display text-4xl font-bold leading-tight sm:text-5xl">
            Belanja langsung dari warung dan mitra koperasi Anda
          </h1>
          <p class="mt-4 max-w-md text-sm leading-relaxed text-white/70">
            Setiap pembelian mendukung UMKM lokal dan otomatis menambah poin simpanan sukarela
            anggota.
          </p>
          <a
            href="/products"
            class="mt-7 inline-flex items-center gap-2 rounded-lg bg-white px-5 py-2.5 text-sm font-bold text-brand transition-colors hover:bg-cream"
          >
            Mulai Belanja
            <span aria-hidden="true">→</span>
          </a>
          <dl class="mt-9 flex gap-10">
            {
              stats.map((stat) => (
                <div>
                  <dt class="sr-only">{stat.label}</dt>
                  <dd class="font-display text-2xl font-bold">{stat.value}</dd>
                  <p class="mt-0.5 text-xs text-white/60">{stat.label}</p>
                </div>
              ))
            }
          </dl>
        </div>
        <ul
          class="w-full max-w-sm space-y-4 rounded-2xl border border-white/15 bg-white/10 p-5 backdrop-blur-sm lg:w-80"
        >
          {
            heroHighlights.map((product) => (
              <li class="flex items-center gap-3">
                <img
                  src={product.image}
                  alt={product.name}
                  loading="lazy"
                  class="h-11 w-11 shrink-0 rounded-lg object-cover"
                />
                <div>
                  <p class="text-sm font-semibold leading-tight">{product.name}</p>
                  <p class="mt-0.5 text-xs text-white/65">{formatIDR(product.price)}</p>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section class="mt-14">
      <div class="flex flex-wrap items-end justify-between gap-3">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-amber-deep">
            Mitra Terpercaya
          </p>
          <h2 class="mt-1 font-display text-2xl font-bold">Belanja dari Toko Anggota</h2>
        </div>
        <a href="/products" class="text-sm font-semibold text-brand hover:underline">
          Lihat semua mitra →
        </a>
      </div>
      <ul class="mt-6 flex flex-wrap gap-3">
        {
          stores.map((store) => (
            <li>
              <a
                href="/products"
                class="flex items-center gap-3 rounded-xl border border-ink/10 bg-white py-2.5 pl-2.5 pr-5 transition-colors hover:border-brand"
              >
                <span
                  class="flex h-9 w-9 items-center justify-center rounded-full bg-brand/10 text-sm font-bold text-brand"
                  aria-hidden="true"
                >
                  {store.name[0]}
                </span>
                <span>
                  <span class="block text-sm font-semibold">{store.name}</span>
                  <span class="block text-xs text-moss">{store.productCount} produk</span>
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="mt-14">
      <div class="flex flex-wrap items-end justify-between gap-3">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-amber-deep">
            Terlaris Minggu Ini
          </p>
          <h2 class="mt-1 font-display text-2xl font-bold">Produk Pilihan Anggota</h2>
        </div>
        <a href="/products" class="text-sm font-semibold text-brand hover:underline">
          Lihat semua produk →
        </a>
      </div>
      <ul class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {
          featured.map((product) => (
            <li>
              <ProductCard product={product} client:visible />
            </li>
          ))
        }
      </ul>
    </section>

    <section class="mt-14 grid gap-5 md:grid-cols-3">
      {
        banners.map((banner) => (
          <div class:list={["rounded-2xl p-6 text-white", banner.class]}>
            <h2 class="font-display text-lg font-bold">{banner.title}</h2>
            <p class="mt-2 text-sm leading-relaxed text-white/85">{banner.body}</p>
          </div>
        ))
      }
    </section>
  </main>
  <SiteFooter />
</Layout>
