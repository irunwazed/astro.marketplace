---
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/features/SiteHeader.astro";
import SiteFooter from "../components/features/SiteFooter.astro";
import CheckoutFlow from "../components/react/CheckoutFlow";
import { dropPoints } from "../data/drop-points";
---

<Layout title="Checkout — Pasar Koperasi">
  <SiteHeader showSearch={false} showCategories={false} />
  <main class="mx-auto max-w-4xl px-4 py-12">
    <header class="mb-7">
      <p class="text-xs font-bold uppercase tracking-[0.18em] text-amber-deep">Belanja</p>
      <h1 class="mt-1 font-display text-3xl font-bold">Checkout</h1>
    </header>
    <CheckoutFlow dropPoints={dropPoints} client:load />
  </main>
  <SiteFooter />
</Layout>
