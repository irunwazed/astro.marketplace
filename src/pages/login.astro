---
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/features/SiteHeader.astro";
import SiteFooter from "../components/features/SiteFooter.astro";
import Card from "../components/ui/Card.astro";
import LoginForm from "../components/react/LoginForm";
---

<Layout title="Masuk — Pasar Koperasi">
  <SiteHeader showSearch={false} showCategories={false} />
  <main class="mx-auto flex max-w-md flex-col px-4 py-16">
    <h1 class="mb-6 text-center font-display text-3xl font-bold">Masuk Anggota</h1>
    <Card class="p-6">
      <LoginForm client:load />
    </Card>
  </main>
  <SiteFooter />
</Layout>
