---
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/features/SiteHeader.astro";
import SiteFooter from "../components/features/SiteFooter.astro";
import ProfileView from "../components/react/ProfileView";
---

<Layout title="Profil — Pasar Koperasi">
  <SiteHeader showSearch={false} showCategories={false} />
  <main class="mx-auto max-w-lg px-4 py-16">
    <h1 class="mb-6 text-center font-display text-3xl font-bold">Profil Saya</h1>
    <ProfileView client:load />
  </main>
  <SiteFooter />
</Layout>
