---
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/features/SiteHeader.astro";
import SiteFooter from "../components/features/SiteFooter.astro";
import ProductBrowser from "../components/react/ProductBrowser";
import { products } from "../data/products";
---

<Layout title="Semua Produk — Pasar Koperasi">
  <SiteHeader showSearch={false} showCategories={false} />
  <main class="mx-auto max-w-6xl px-4 py-10">
    <header class="mb-7">
      <p class="text-xs font-bold uppercase tracking-[0.18em] text-amber-deep">Katalog</p>
      <h1 class="mt-1 font-display text-3xl font-bold">Semua Produk</h1>
      <p class="mt-2 text-sm text-moss">
        Cari dan saring produk UMKM dari mitra koperasi Anda.
      </p>
    </header>
    <ProductBrowser products={products} client:load />
  </main>
  <SiteFooter />
</Layout>
