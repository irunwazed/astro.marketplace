---
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/features/SiteHeader.astro";
import SiteFooter from "../components/features/SiteFooter.astro";
import WishlistView from "../components/react/WishlistView";
---

<Layout title="Wishlist — Pasar Koperasi">
  <SiteHeader showSearch={false} showCategories={false} />
  <main class="mx-auto max-w-5xl px-4 py-10">
    <header class="mb-7">
      <p class="text-xs font-bold uppercase tracking-[0.18em] text-amber-deep">Belanja</p>
      <h1 class="mt-1 font-display text-3xl font-bold">Wishlist Saya</h1>
      <p class="mt-2 text-sm text-moss">Produk yang Anda simpan untuk dibeli nanti.</p>
    </header>
    <WishlistView client:load />
  </main>
  <SiteFooter />
</Layout>